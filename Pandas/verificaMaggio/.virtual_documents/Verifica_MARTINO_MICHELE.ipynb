











import numpy as np
import pandas as pd
from sklearn.preprocessing import LabelEncoder
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier


data = pd.read_csv("stars.csv")
data.head(5)


data.info()


# Sistemo i dati tramite labelEncoder, campi: star color e spectral class


labelEncoder_color = LabelEncoder()
labelEncoder_class = LabelEncoder()


data["color_n"] = labelEncoder_color.fit_transform(data["Star color"])
data["spectral_n"] = labelEncoder_class.fit_transform(data["Spectral Class"])


data.columns


# Ora ho tutte le colonne che mi interessano, divido in features e output


features = ['Temperature (K)', 'Luminosity(L/Lo)', 'Radius(R/Ro)',
       'Absolute magnitude(Mv)', 'color_n', 'spectral_n']
output = ["Star type"]

selected_data = data[features+output]

X = selected_data[features].to_numpy()
y = selected_data[output].to_numpy()


#Splitto i dati


X_train, X_test, y_train, y_test = train_test_split(X, y, random_state = 42, test_size = 0.33)


# Creo la foresta con tutte le features, non ha bisogno di standardScaler


rf = RandomForestClassifier(max_depth = 6, n_estimators = 1000)
rf.fit(X_train, y_train.reshape(-1))


rf.score(X_test, y_test)


for feature, importance in zip(features, rf.feature_importances_):
    print(f'{feature}: {importance}')








from sklearn.neural_network import MLPClassifier
from sklearn.preprocessing import StandardScaler
import matplotlib.pyplot as plt


#Devo normalizzare la mia X e rifare lo split, le feature importanti che uso sono le 3 scoperte sopra


features = ['Luminosity(L/Lo)', 'Radius(R/Ro)',
       'Absolute magnitude(Mv)']
output = ["Star type"]

selected_data = data[features+output]

X = selected_data[features].to_numpy()
y = selected_data[output].to_numpy()

scaler = StandardScaler()

X_norm = scaler.fit_transform(X)


X_train, X_test, y_train, y_test = train_test_split(X_norm, y, random_state = 42, test_size = 0.33)


# Verifico il minimo numero di neuroni per il mlpClassifier


n_neuroni = list(range(1, 10))
lista_score_training = []
lista_score_test = []
for neurone in n_neuroni:
    neural_network = MLPClassifier(hidden_layer_sizes = (neurone, 4), max_iter = 10000)
    neural_network.fit(X_train, y_train.reshape(-1))
    lista_score_training.append(neural_network.score(X_train, y_train))
    lista_score_test.append(neural_network.score(X_test, y_test))



fig, ax = plt.subplots(figsize = (4,4))
ax.plot(n_neuroni, lista_score_training, color="green", label="training")
ax.plot(n_neuroni, lista_score_test, color="red", label="test")
ax.set_xlabel("n_neuroni")
ax.set_ylabel("score")
ax.grid()
ax.legend()
plt.show()


# Dai grafici sembra che con 8 neuroni si trovi il picco


neural_network = MLPClassifier(hidden_layer_sizes = (8, 4), max_iter = 10000)
neural_network.fit(X_train, y_train.reshape(-1))


neural_network.score(X_test, y_test)






