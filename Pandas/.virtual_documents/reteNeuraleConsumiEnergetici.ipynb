import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from sklearn.preprocessing import LabelEncoder
from sklearn.model_selection import train_test_split
from sklearn.linear_model import LinearRegression


data = pd.read_csv("train_energy_data.csv")


data.head()


data.info()





LabelEncoder_building = LabelEncoder()
LabelEncoder_day = LabelEncoder()


data["building_type_n"] = LabelEncoder_building.fit_transform(data["Building Type"])
data["day_n"] = LabelEncoder_day.fit_transform(data["Day of Week"])


data.columns


feature = ['Square Footage', 'Number of Occupants',
       'Appliances Used', 'Average Temperature',
        'building_type_n', 'day_n']
output = ['Energy Consumption']
selected_data = data[feature+output]

X = selected_data[feature].to_numpy()
y = selected_data[output].to_numpy()


X_train, X_test, y_train, y_test = train_test_split(X, y, random_state=42, test_size=0.3)


regressore = LinearRegression()


regressore.fit(X_train, y_train)


regressore.score(X_test, y_test)



