import numpy as np
import matplotlib.pyplot as plt
import pandas as pd
from sklearn.preprocessing import LabelEncoder
from sklearn.model_selection import train_test_split
from sklearn.linear_model import LinearRegression


data = pd.read_csv("Used_fiat_500_in_Italy_dataset.csv")
data.head()


data.info()


labelEncoder_model = LabelEncoder()
data['model_n'] = labelEncoder_model.fit_transform(data["model"])

labelEncoder_transmission = LabelEncoder()
data['transmission_n'] = labelEncoder_transmission.fit_transform(data["transmission"])

data.head()


data.columns


feature = ['engine_power', 'age_in_days', 'km',
       'previous_owners', 'lat', 'lon', 'model_n', 'transmission_n']
output = ["price"]
selected_data = data[feature+output]
selected_data.head()


X = selected_data[feature].to_numpy()
y = selected_data[output].to_numpy()


X_train, X_test, y_train, y_test = train_test_split(X, y, random_state=42, test_size=0.3)


regressor = LinearRegression()


regressor.fit(X_train, y_train) #addestra le regressione lineare


regressor.score(X_test, y_test)


feature


#Una fiat 500 campione

engine_power = 70
age_in_days = 600
km = 65_000
previous_owners = 1
lat = 44.3
lon = 7.5
model = "pop"
transmission = "manual"


model_n = labelEncoder_model.transform([model])[0]
transmission_n = labelEncoder_transmission.transform([transmission])[0]


fiat500 = [engine_power,
 age_in_days,
 km,
 previous_owners,
 lat,
 lon,
 model_n,
 transmission_n]

fiat500


regressor.predict([fiat500])


from joblib import dump 
#Il file contiene la rete neurale addestrata con tutti i suoi metodi
dump(regressor, 'regressore_500.dump')





from joblib import dump

dump(labelEncoder_model, 'labelEncoder_model.joblib')
dump(labelEncoder_transmission, 'labelEncoder_transmission.joblib')
