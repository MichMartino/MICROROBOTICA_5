import numpy as np
import matplotlib.pyplot as plt


img = plt.imread("./images.jpeg")
_, w, _ = img.shape
mid = w // 2

copia = img.copy()
img_swapped_l = copia[:, :mid, :]
img_swapped_r = copia[:, mid:, :]
#copia[:, :mid, :] = img_swapped_r
#copia[:, mid:, :] = img_swapped_l

#metodo del professor tosello
immagine = np.concatenate((img_swapped_r, img_swapped_l), axis = 1)
#Tolgo il blu
immagine[:, :, 2] = 0

plt.imshow(immagine)


#Ex 2


import numpy as np
import matplotlib.pyplot as plt


N = 8
x = np.arange(N) + 1
print(x)
y = np.arange(N)
print(y)


matr = np.add.outer(x, y) #add è un insieme di funzioni che fa le combo tra le varie funzioni
print(matr)


matr = matr % 2
matr


matr = matr.astype(float)
matr


plt.imshow(matr, cmap = "grey")


#rumore = np.random.uniform(
noise = 0.8+0.2*np.random.rand(N, N)


matr = matr*noise
plt.imshow(matr, cmap = "grey")


