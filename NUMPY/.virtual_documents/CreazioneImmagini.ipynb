#EX 12 creazione immagini 
import numpy as np
import matplotlib.pyplot as plt


SIZE = (200, 200, 3) #200 * 200 con 3 canali
img = np.zeros(SIZE) #immagine nera
plt.imshow(img)


# x^2 + y^2 <= r^2
#Vogliamo fare il cerchio al centro dell'immagine con raggio r
#l'equazione sarà (x - xcentro)^2 + (y - ycentro)^2 <= r


x = np.arange(0, SIZE[0])
y = np.arange(0, SIZE[1])


x_matrix, y_matriy = np.meshgrid(x, y)


x_matrix


y_matriy


x_c, y_c = SIZE[0] // 2, SIZE[1] // 2
r = 50
disk = (x_matrix - x_c)**2 + (y_matriy - y_c)**2 <= r**2


img[disk] = np.array([0., 1., 0.]) #red 0 green 1 blue 0
plt.imshow(img)



